# CricPulse AI — Environment Variables
# Copy this to .env and fill in your values

# Server port (Cloud Run uses PORT env automatically)
PORT=5000

# Google Gemini API — Get free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# CricAPI free tier — Get key at https://cricapi.com (100 free calls/day)
# If empty, platform runs in high-fidelity simulation mode
CRICKET_API_KEY=your_cricket_api_key_here

# Node environment
NODE_ENV=production
